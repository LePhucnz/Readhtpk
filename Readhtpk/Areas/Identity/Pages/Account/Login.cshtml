@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="login-page">
    <div style="width:100%;max-width:920px;display:grid;grid-template-columns:1fr 1fr;border-radius:var(--radius-xl);overflow:hidden;box-shadow:var(--shadow-lg);border:1px solid var(--border);">

        <!-- Left panel -->
        <div style="background:var(--brand);padding:3rem 2.5rem;display:flex;flex-direction:column;justify-content:center;color:#fff;">
            <div style="font-family:'Sora',sans-serif;font-size:26px;font-weight:700;margin-bottom:8px;">
                <i class="bi bi-mortarboard-fill me-2"></i>Readhtpk
            </div>
            <div style="font-size:18px;font-weight:600;margin-bottom:12px;opacity:0.95;">
                Nền tảng thi trắc nghiệm chuyên nghiệp
            </div>
            <p style="font-size:14px;opacity:0.80;line-height:1.7;margin-bottom:2rem;">
                Hệ thống quản lý đề thi và luyện tập trực tuyến dành cho học sinh, giáo viên và quản trị viên.
            </p>
            <div style="display:flex;flex-direction:column;gap:12px;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-shield-check-fill" style="font-size:16px;"></i>
                    </div>
                    <span style="font-size:14px;font-weight:500;">Bảo mật tài khoản cao</span>
                </div>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-graph-up-arrow" style="font-size:16px;"></i>
                    </div>
                    <span style="font-size:14px;font-weight:500;">Theo dõi tiến độ học tập</span>
                </div>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="width:36px;height:36px;border-radius:10px;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                        <i class="bi bi-shuffle" style="font-size:16px;"></i>
                    </div>
                    <span style="font-size:14px;font-weight:500;">Câu hỏi xáo trộn thông minh</span>
                </div>
            </div>
        </div>

        <!-- Right panel: form -->
        <div style="background:var(--surface);padding:3rem 2.5rem;">
            <div style="font-family:'Sora',sans-serif;font-size:22px;font-weight:700;color:var(--text-primary);margin-bottom:4px;">Chào mừng trở lại!</div>
            <p style="font-size:14px;color:var(--text-muted);margin-bottom:1.8rem;">Đăng nhập để tiếp tục.</p>

            <form asp-area="Identity" asp-page="/Account/Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">E-mail</label>
                    <div style="position:relative;">
                        <i class="bi bi-envelope" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:14px;"></i>
                        <input asp-for="Input.Email" class="form-control" style="padding-left:36px;" autocomplete="username" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="mb-3">
                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                        <label class="form-label mb-0">Mật khẩu</label>
                        <a asp-area="Identity" asp-page="/Account/ForgotPassword"
                               style="font-size:12px;color:var(--brand);text-decoration:none;font-weight:600;">
                            Quên mật khẩu?
                        </a>
                    </div>
                    <div style="position:relative;">
                        <i class="bi bi-lock" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:14px;"></i>
                        <input asp-for="Input.Password" class="form-control" style="padding-left:36px;" autocomplete="current-password" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger" style="font-size:12px;"></span>
                </div>

                <div class="mb-4" style="display:flex;align-items:center;gap:8px;">
                    <input asp-for="Input.RememberMe" type="checkbox" style="accent-color:var(--brand);width:16px;height:16px;" />
                    <label asp-for="Input.RememberMe" style="font-size:13px;color:var(--text-secondary);cursor:pointer;">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100" style="justify-content:center;">
                    <i class="bi bi-box-arrow-in-right"></i> Đăng nhập
                </button>

                <div class="login-divider">hoặc</div>

                <div style="display:flex;flex-direction:column;gap:8px;text-align:center;">
                    <a asp-area="Identity" asp-page="/Account/Register"
                           style="font-size:13px;color:var(--brand);text-decoration:none;font-weight:600;">
                        <i class="bi bi-person-plus me-1"></i> Đăng ký tài khoản mới
                    </a>
                    <a asp-area="Identity" asp-page="/Account/ResendEmailConfirmation"
                           style="font-size:13px;color:var(--text-muted);text-decoration:none;">
                        <i class="bi bi-envelope me-1"></i> Gửi lại email xác nhận
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}