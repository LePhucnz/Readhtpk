@model IEnumerable<Readhtpk.Models.Exam>
@{
    ViewData["Title"] = "Đề thi";
}

<div class="mt-4">
    <div class="page-header">
        <div>
            <h2><i class="bi bi-file-earmark-text-fill me-2" style="color:var(--brand);"></i>Danh sách Đề thi</h2>
            <p class="subtitle">Quản lý các đề thi trong hệ thống</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Tạo mới
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="table-wrapper">
            <div class="empty-state" style="padding:5rem 2rem;">
                <div class="empty-state-icon"><i class="bi bi-file-earmark-text"></i></div>
                <strong>Chưa có đề thi nào</strong>
                <p>Nhấn "Tạo mới" để tạo đề thi đầu tiên.</p>
                <a asp-action="Create" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-lg"></i> Tạo đề thi ngay
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="stats-row">
            <div class="stat-card">
                <div class="stat-icon blue"><i class="bi bi-file-earmark-text-fill"></i></div>
                <div><div class="stat-value">@Model.Count()</div><div class="stat-label">Tổng đề thi</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon green"><i class="bi bi-check-circle-fill"></i></div>
                <div><div class="stat-value" style="color:var(--success);">@Model.Count(e => e.IsActive)</div><div class="stat-label">Đang mở</div></div>
            </div>
            <div class="stat-card">
                <div class="stat-icon red"><i class="bi bi-x-circle-fill"></i></div>
                <div><div class="stat-value" style="color:var(--danger);">@Model.Count(e => !e.IsActive)</div><div class="stat-label">Đã đóng</div></div>
            </div>
        </div>

        <div class="table-wrapper">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>Tên đề thi</th>
                        <th style="width:130px;">Môn học</th>
                        <th style="width:100px;">Thời gian</th>
                        <th style="width:90px;">Tổng điểm</th>
                        <th style="width:120px;">Trạng thái</th>
                        <th style="width:180px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><div class="cell-name">@item.Title</div></td>
                            <td style="color:var(--text-secondary);font-size:13px;">@item.Subject?.Name</td>
                            <td>
                                <span style="font-size:13px;font-weight:500;">
                                    <i class="bi bi-clock me-1" style="color:var(--brand);"></i>@item.DurationMinutes phút
                                </span>
                            </td>
                            <td>
                                <span class="badge bg-primary">@item.TotalMarks đ</span>
                            </td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Đang mở</span>
                                }
                                else
                                {

                                    <span class="badge bg-danger"><i class="bi bi-circle-fill" style="font-size:7px;"></i> Đã đóng</span>
                                }
                            </td>
                            <td>
                                <div class="action-group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil-fill"></i> Sửa</a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info"><i class="bi bi-eye-fill"></i> Chi tiết</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash-fill"></i> Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>