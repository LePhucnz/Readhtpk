@model IEnumerable<Readhtpk.Models.Question>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-question-circle"></i> Danh sách Câu hỏi</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo mới</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th>Nội dung</th>
                        <th>Môn học</th>
                        <th>Đáp án đúng</th>
                        <th>Độ khó</th>
                        <th style="width: 150px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Content)</td>
                            <td>@Html.DisplayFor(modelItem => item.Subject!.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.CorrectAnswer)</td>
                            <td>
                                @if (item.Difficulty == 1)
                                {
                                    <span class="badge bg-success">Dễ</span>
                                }
                                else if (item.Difficulty == 2)
                                {
                                    <span class="badge bg-warning">Trung bình</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Khó</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>