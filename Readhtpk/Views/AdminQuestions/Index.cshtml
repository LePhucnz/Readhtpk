@model IEnumerable<Readhtpk.Models.Question>
@{
    ViewData["Title"] = "Câu hỏi";
    var easy = Model.Count(q => q.Difficulty == 1);
    var med = Model.Count(q => q.Difficulty == 2);
    var hard = Model.Count(q => q.Difficulty >= 3);
}

<div class="mt-4">
    <div class="page-header">
        <div>
            <h2><i class="bi bi-question-diamond-fill me-2" style="color:var(--brand);"></i>Danh sách Câu hỏi</h2>
            <p class="subtitle">Quản lý ngân hàng câu hỏi của hệ thống</p>
        </div>
        <div class="action-group">
            <a asp-action="Import" class="btn btn-success"><i class="bi bi-file-earmark-excel-fill"></i> Import Excel</a>
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Tạo mới</a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-3">
            <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-ui-checks"></i></div>
            <div><div class="stat-value">@Model.Count()</div><div class="stat-label">Tổng câu hỏi</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-emoji-smile-fill"></i></div>
            <div><div class="stat-value" style="color:var(--success);">@easy</div><div class="stat-label">Câu dễ</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon amber"><i class="bi bi-emoji-neutral-fill"></i></div>
            <div><div class="stat-value" style="color:var(--warning);">@med</div><div class="stat-label">Trung bình</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-emoji-frown-fill"></i></div>
            <div><div class="stat-value" style="color:var(--danger);">@hard</div><div class="stat-label">Câu khó</div></div>
        </div>
    </div>

    <div class="table-wrapper">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Nội dung câu hỏi</th>
                    <th style="width:130px;">Môn học</th>
                    <th style="width:120px;">Đáp án đúng</th>
                    <th style="width:110px;">Độ khó</th>
                    <th style="width:180px;">Chức năng</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="max-width:400px;">
                            <div style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;font-weight:500;">
                                @Html.DisplayFor(m => item.Content)
                            </div>
                        </td>
                        <td style="color:var(--text-secondary);font-size:13px;font-weight:500;">@Html.DisplayFor(m => item.Subject!.Name)</td>
                        <td>
                            <span class="badge bg-primary" style="font-size:12px;">
                                <i class="bi bi-check2-circle me-1"></i>@Html.DisplayFor(m => item.CorrectAnswer)
                            </span>
                        </td>
                        <td>
                            @if (item.Difficulty == 1)
                            {
                                <span class="badge bg-success">Dễ</span>
                            }
                            else if (item.Difficulty == 2)
                            {

                                <span class="badge bg-warning">Trung bình</span>
                            }
                            else
                            {

                                <span class="badge bg-danger">Khó</span>
                            }
                        </td>
                        <td>
                            <div class="action-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning"><i class="bi bi-pencil-fill"></i> Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info"><i class="bi bi-eye-fill"></i> Chi tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger"><i class="bi bi-trash-fill"></i> Xóa</a>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <div class="empty-state-icon"><i class="bi bi-question-diamond"></i></div>
                                <strong>Chưa có câu hỏi nào</strong>
                                <p>Nhấn "Tạo mới" hoặc "Import Excel" để bắt đầu.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>