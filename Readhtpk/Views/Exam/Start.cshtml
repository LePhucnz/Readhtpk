@model IEnumerable<Readhtpk.Models.ViewModels.QuestionViewModel>
@{
    ViewData["Title"] = ViewBag.ExamTitle ?? "Làm bài thi";
    int index = 0;
}

<div class="container mt-4">
    <div class="exam-header card mb-4">
        <div class="card-body">
            <h4 class="card-title">@ViewBag.ExamTitle</h4>
            <p class="card-text">
                ⏱ Thời gian: <strong>@ViewBag.DurationMinutes phút</strong> |
                📊 Tổng điểm: <strong>@ViewBag.TotalMarks</strong>
            </p>
            <div id="timer" class="alert alert-warning mb-0">
                Thời gian còn lại: <span id="timeDisplay">@ViewBag.DurationMinutes:00</span>
            </div>
        </div>
    </div>

    <form asp-action="Submit" method="post" id="examForm">
        @foreach (var q in Model)
        {
            <div class="question-card card mb-3">
                <div class="card-body">
                    <p class="fw-bold">Câu @(++index): @q.Content</p>
                    
                    <!-- Hidden field để lưu QuestionId -->
                    <input type="hidden" name="answers[@(index - 1)].QuestionId" value="@q.Id" />
                    
                    <div class="answers-list">
                        <label class="answer-option d-block mb-2">
                            <input type="radio" name="answers[@(index - 1)].SelectedAnswer" value="A" required />
                            <strong>A.</strong> @q.AnswerA
                        </label>
                        <label class="answer-option d-block mb-2">
                            <input type="radio" name="answers[@(index - 1)].SelectedAnswer" value="B" />
                            <strong>B.</strong> @q.AnswerB
                        </label>
                        <label class="answer-option d-block mb-2">
                            <input type="radio" name="answers[@(index - 1)].SelectedAnswer" value="C" />
                            <strong>C.</strong> @q.AnswerC
                        </label>
                        <label class="answer-option d-block mb-2">
                            <input type="radio" name="answers[@(index - 1)].SelectedAnswer" value="D" />
                            <strong>D.</strong> @q.AnswerD
                        </label>
                    </div>
                </div>
            </div>
        }
        
        <div class="exam-actions mt-4 mb-5">
            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn">
                📤 Nộp bài
            </button>
            <a asp-action="History" class="btn btn-secondary btn-lg">❌ Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // ⏱ Đồng hồ đếm ngược (Bạn 4 có thể mở rộng thêm)
        let totalSeconds = @ViewBag.DurationMinutes * 60;
        const timeDisplay = document.getElementById('timeDisplay');
        const examForm = document.getElementById('examForm');
        
        const timer = setInterval(() => {
            let mins = Math.floor(totalSeconds / 60);
            let secs = totalSeconds % 60;
            timeDisplay.textContent = `${mins}:${secs < 10 ? '0' : ''}${secs}`;
            
            // Cảnh báo khi còn 5 phút
            if (totalSeconds <= 300) {
                document.getElementById('timer').classList.add('alert-danger');
            }
            
            if (totalSeconds <= 0) {
                clearInterval(timer);
                alert('⏰ Hết giờ! Bài thi sẽ được tự động nộp.');
                examForm.submit();
            }
            totalSeconds--;
        }, 1000);

        // 🚫 Chống chuyển tab (Bạn 4 có thể bổ sung thêm)
        document.addEventListener('visibilitychange', function() {
            if (document.hidden) {
                console.warn('⚠️ User switched tab');
                // Có thể thêm logic cảnh báo hoặc ghi log
            }
        });
    </script>
}